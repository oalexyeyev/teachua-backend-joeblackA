# /etc/environment проксі налаштування

{% if http_proxy is defined %}
HTTP_PROXY="{{ http_proxy }}"
http_proxy="{{ http_proxy }}"
{% endif %}

{% if https_proxy is defined %}
HTTPS_PROXY="{{ https_proxy }}"
https_proxy="{{ https_proxy }}"
{% endif %}

{% if no_proxy is defined %}
NO_PROXY="{{ no_proxy }}"
no_proxy="{{ no_proxy }}"
{% endif %}
